---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const servicosEntries = await getCollection('servicos');
	return servicosEntries.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Andaime PRO - Detalhes Técnicos`}>
	<main class="bg-slate-50">
		<!-- 1. Hero Estilo Print -->
		<section class="relative py-32 md:py-48 bg-slate-950 text-center text-white overflow-hidden">
			<!-- Overlay de imagem de fundo simulado -->
			<div class="absolute inset-0 opacity-40 bg-[url('https://images.unsplash.com/photo-1541888946425-d81bb19480c5?auto=format&fit=crop&q=80&w=2000')] bg-cover bg-center"></div>
			<div class="absolute inset-0 bg-gradient-to-b from-slate-950/60 to-slate-950"></div>

			<div class="container relative z-10">
				<a href="/servicos" class="inline-flex items-center gap-2 px-6 py-2 bg-white/10 backdrop-blur-md rounded-full text-sm font-black hover:bg-white hover:text-slate-950 hover:scale-105 active:scale-95 transition-all mb-12 border border-white/20">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					Voltar para Galeria
				</a>
				<h1 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter leading-[1.1]">{entry.data.title}</h1>
				<p class="text-xl md:text-2xl text-gray-100 max-w-2xl mx-auto opacity-90 font-medium italic">{entry.data.description}</p>
			</div>
		</section>

		<!-- 2. Conteúdo e Sidebar -->
		<section class="py-24">
			<div class="container">
				<div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
					
					<!-- Coluna Principal (8 Colunas) -->
					<div class="lg:col-span-8 space-y-16">
						
						<!-- Descrição -->
						<div class="bg-white p-12 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100">
							<div class="flex items-center gap-4 mb-10">
								<div class="w-1.5 h-8 bg-primary rounded-full"></div>
								<h2 class="text-3xl font-black text-slate-950 uppercase tracking-tighter">Visão Geral</h2>
							</div>
							<article class="prose prose-xl prose-slate max-w-none prose-headings:text-slate-950 prose-headings:font-black prose-p:text-slate-600 prose-p:font-medium prose-p:leading-relaxed">
								<Content />
							</article>
						</div>

						<!-- Características -->
						{entry.data.characteristics && (
							<div class="bg-white p-12 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100">
								<h2 class="text-2xl font-black text-slate-950 mb-10 uppercase tracking-tighter">Diferenciais Técnicos</h2>
								<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
									{entry.data.characteristics.map(char => (
										<div class="flex items-center gap-4 bg-slate-50 p-6 rounded-2xl border border-slate-100 group hover:border-primary transition-colors">
											<div class="w-8 h-8 bg-primary/10 text-primary rounded-full flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-all">
												<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
												</svg>
											</div>
											<span class="font-bold text-slate-900 tracking-tight">{char}</span>
										</div>
									))}
								</div>
							</div>
						)}

						<!-- Especificações -->
						{entry.data.specs && (
							<div class="bg-white p-12 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100">
								<h2 class="text-2xl font-black text-slate-950 mb-10 uppercase tracking-tighter">Ficha Técnica</h2>
								<div class="grid grid-cols-2 md:grid-cols-3 gap-8">
									{Object.entries(entry.data.specs).map(([key, value]) => (
										<div class="space-y-2 group">
											<p class="text-xs font-black text-primary uppercase tracking-[0.2em]">{key}</p>
											<p class="text-xl font-black text-slate-950 group-hover:translate-x-1 transition-transform">{value}</p>
										</div>
									))}
								</div>
							</div>
						)}

						<!-- Garantias -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8">
							<div class="bg-slate-950 p-10 rounded-[2.5rem] flex gap-6 text-white group hover:scale-105 transition-all">
								<div class="text-4xl group-hover:rotate-12 transition-transform">🛡️</div>
								<div>
									<h4 class="font-black text-primary mb-2 text-xl tracking-tighter">Segurança Total</h4>
									<p class="text-gray-300 font-medium">Equipamento certificado e revisado em conformidade com a NR-18.</p>
								</div>
							</div>
							<div class="bg-primary p-10 rounded-[2.5rem] flex gap-6 text-white group hover:scale-105 transition-all">
								<div class="text-4xl group-hover:rotate-12 transition-transform">🚛</div>
								<div>
									<h4 class="font-black text-slate-950 mb-2 text-xl tracking-tighter">Entrega Imediata</h4>
									<p class="text-white font-medium">Frota própria disponível para atendimento em tempo recorde (até 2h).</p>
								</div>
							</div>
						</div>

					</div>

					<!-- Sidebar Sticky -->
					<div class="lg:col-span-4 lg:sticky lg:top-32">
						<div class="bg-white p-10 rounded-[3rem] shadow-2xl border border-slate-100 text-center relative overflow-hidden">
							<div class="absolute top-0 left-0 w-full h-2 bg-primary"></div>
							
							<p class="text-primary font-black text-xs uppercase tracking-[0.2em] mb-4">Central de Negócios</p>
							<h3 class="text-2xl font-black text-slate-950 mb-10 tracking-tighter">Interessado neste <br/> equipamento?</h3>
							
							<div class="space-y-6">
								<a href="https://wa.me/5511998765432" target="_blank" class="w-full bg-slate-950 text-white p-8 rounded-2xl font-black text-xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-slate-950/20 block">
									WhatsApp Oficial
								</a>
								<a href="tel:551133445566" class="w-full bg-white border-2 border-slate-950 text-slate-950 p-8 rounded-2xl font-black text-xl hover:bg-slate-950 hover:text-white transition-all block flex items-center justify-center gap-3">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
									</svg>
									Ligar Agora
								</a>
							</div>
							
							<div class="mt-12 pt-10 border-t border-slate-100">
								<p class="text-slate-400 font-bold text-sm mb-4 uppercase tracking-widest">Suporte 24h Especializado</p>
								<p class="text-3xl font-black text-slate-950 tracking-tighter">(11) 3344-5566</p>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>
	</main>
</Layout>

